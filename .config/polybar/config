format-connected-prefix-foreground = ${colors.foreground-alt}
label-connected = %local_ip%

format-disconnected =

[module/date]
type = internal/date
interval = 5

date = "%Y-%m-%d  %a " 

time = %H:%M

label = %date% %time%

[module/pulseaudio]
